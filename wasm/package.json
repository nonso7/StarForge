{
  "name": "starforge-wasm",
  "version": "0.1.0",
  "description": "StarForge WebAssembly bindings",
  "main": "pkg/starforge_wasm.js",
  "types": "pkg/starforge_wasm.d.ts",
  "files": [
    "pkg/"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --release",
    "build:dev": "wasm-pack build --target web --dev",
